# TrafficGuard AI Environment Configuration

# Application
APP_NAME=TrafficGuard AI
APP_ENV=development
DEBUG=true
SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
API_V1_PREFIX=/api/v1

# Database
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=trafficguard
POSTGRES_PASSWORD=trafficguard_secret
POSTGRES_DB=trafficguard
DATABASE_URL=postgresql+asyncpg://trafficguard:trafficguard_secret@postgres:5432/trafficguard

# Redis
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# MinIO
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=trafficguard
MINIO_SECRET_KEY=trafficguard_minio_secret
MINIO_BUCKET=trafficguard-evidence
MINIO_SECURE=false

# Elasticsearch
ELASTICSEARCH_URL=http://elasticsearch:9200
ELASTICSEARCH_INDEX=trafficguard

# JWT
JWT_SECRET_KEY=change-me-jwt-secret-key
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# AI / ML
YOLO_MODEL_PATH=ml/models/yolov8s.pt
MC_DROPOUT_PASSES=5
ROBOFLOW_API_KEY=

# Vision enforcement — plate, violation, Indian MV Act fine (gemini-2.5-flash)
GEMINI_API_KEY=
GEMINI_PRIMARY_ENABLED=true
GEMINI_VERIFY_ENABLED=true
CONFIDENCE_AUTO_THRESHOLD=0.85
CONFIDENCE_REVIEW_THRESHOLD=0.60

# Routing thresholds
AUTO_PROCESS_THRESHOLD=0.85
HUMAN_REVIEW_THRESHOLD=0.60

# Frontend
# Frontend (leave empty in dev to use Vite proxy — avoids CORS)
VITE_API_URL=
VITE_MAPBOX_TOKEN=your_mapbox_token_here

# CORS
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
